---
import CallToAction from './CallToAction.astro'
import { Heading, Link } from 'accessible-astro-components'
import { Icon } from 'astro-icon/components'

const currentYear = new Date().getFullYear()
---

<footer class="site-footer">

  <!-- CTA stays -->
  <CallToAction />

  <section class="footer-main">
    <Heading level="h2" class="sr-only">Footer</Heading>

    <div class="container footer-grid">

      <div class="footer-brand">
        <h3>Amanda Shafack</h3>
      </div>

      <nav class="footer-nav" aria-label="Footer navigation">
        <ul>
          <li><Link href="/">Home</Link></li>
          <li><Link href="/about">About</Link></li>
          <li><Link href="/projects">Projects</Link></li>
          <li><Link href="/contact">Contact</Link></li>
        </ul>
      </nav>

    </div>
  </section>

  <section class="footer-bottom">
    <div class="container footer-bottom-grid">

      <p class="footer-copy">
        © {currentYear} Amanda Shafack. All Rights Reserved.
      </p>

      <ul class="footer-socials">

        <li>
          <Link href="https://github.com/lkmandy" isExternal class="social-button" hideIcon={true}>
            <Icon name="lucide:github" size="20" />
          </Link>
        </li>

        <li>
          <Link href="https://linkedin.com/in/lkmandy" isExternal class="social-button" hideIcon={true}>
            <Icon name="lucide:linkedin" size="20" />
          </Link>
        </li>

        <li>
          <Link href="https://twitter.com/lkmandy" isExternal class="social-button" hideIcon={true}>
            <Icon name="lucide:twitter" size="20" />
          </Link>
        </li>

        <li>
          <Link href="mailto:shafack.likhene@gmail.com" class="social-button" hideIcon={true}>
            <Icon name="lucide:mail" size="20" />
          </Link>
        </li>

        <li>
          <Link href="/resume.pdf" class="social-button" hideIcon={true}>
            <Icon name="lucide:download" size="20" />
          </Link>
        </li>

      </ul>

    </div>
  </section>

</footer>

<style lang="scss">

.site-footer{
  margin-top: 6rem;
}

/* top row */

.footer-main{
  padding-block: 4rem 2rem;
  border-top:1px solid var(--border-color-subtle);
}

.footer-grid{
  display:flex;
  justify-content:space-between;
  align-items:center;
  flex-wrap:wrap;
  gap:2rem;
}

.footer-brand h3{
  font-size:clamp(2rem,4vw,3rem);
  font-weight:600;
  margin:0;
}

/* navigation */

.footer-nav ul{
  display:flex;
  gap:2rem;
  list-style:none;
  margin:0;
  padding:0;
}

.footer-nav :global(a){
  text-decoration:none;
  font-size:1.1rem;
  font-weight:500;
}

.footer-nav :global(a:hover){
  color:var(--brand-secondary);
}

/* bottom row */

.footer-bottom{
  border-top:1px solid var(--border-color-subtle);
  padding-block:2rem;
}

.footer-bottom-grid{
  display:flex;
  justify-content:space-between;
  align-items:center;
  flex-wrap:wrap;
  gap:1.5rem;
}

.footer-copy{
  margin:0;
  opacity:.8;
}

/* social icons */

.footer-socials{
  display:flex;
  gap:1rem;
  list-style:none;
  margin:0;
  padding:0;
}

.social-button{
  width:3rem;
  height:3rem;
  border-radius:999px;
  display:flex;
  align-items:center;
  justify-content:center;
  text-decoration:none !important;
  border:1px solid var(--border-color-subtle);
  background:light-dark(#ffffff,#1a1a1a);
  color:light-dark(#111,#fff);
  transition:all .2s ease;
}

.social-button:hover{
  transform:translateY(-2px);
  background:var(--brand-secondary);
  border-color:var(--brand-secondary);
  color:white;
}

</style>