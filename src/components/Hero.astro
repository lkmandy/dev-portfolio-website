---
import { Link } from 'accessible-astro-components'
import { Icon } from 'astro-icon/components'
import { Image } from 'astro:assets'

import profileImg from '@assets/images/profile/amanda-shafack.jpg'
---

<section class="hero my-24">
  <div class="container">
    <div class="grid grid-cols-1 items-center gap-16 lg:grid-cols-2">
      <div class="flex flex-col items-center gap-6 md:items-start">
        <h1 class="text-center text-4xl font-extrabold tracking-tight whitespace-nowrap md:text-5xl lg:text-6xl">
          <span>Full-Stack Developer</span>
        </h1>

        <p class="max-w-xl text-center text-xl opacity-90 md:text-left">
           Hello World! I'm <span class="font-extrabold">Amanda Shafack</span> I build accessible web and mobile experiences with Flutter, React, Node.js, and MongoDB
        </p>

        <div class="flex flex-col gap-3 min-[500px]:flex-row">
          <Link href="/portfolio" isButton type="primary" animateOnHover animationType="boop">
            View projects
          </Link>

          <Link href="/contact" isButton type="secondary" animateOnHover animationType="boop">
            Contact me
          </Link>
        </div>
      </div>

      <div class="hidden justify-center lg:flex">
        <div class="photo-frame" aria-hidden="true">
          <Image
            src={profileImg}
            alt="Portrait of Amanda Shafack"
            width={640}
            height={640}
            loading="eager"
            decoding="async"
            class="photo"
          />
        </div>
      </div>
    </div>
  </div>
</section>

<style lang="scss">
  .photo-frame {
    position: relative;
    box-shadow: 0 20px 60px rgba(0, 0, 0, 0.18);
    border-radius: 999px;
    background: linear-gradient(
      135deg,
      light-dark(var(--brand-white-300), var(--brand-white-200)),
      light-dark(var(--brand-white-300), var(--brand-white-200))
    );
    padding: 10px;
    aspect-ratio: 1 / 1;
    width: min(420px, 100%);
  }

  .photo {
    border-radius: 999px;
    background: var(--background-color);
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
</style>
